{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WinChronicle read-only MCP tool result",
  "type": "object",
  "required": [
    "tool",
    "read_only",
    "trust",
    "instruction",
    "metadata_only",
    "share_warning",
    "external_sharing",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "tool": {
      "type": "string",
      "enum": [
        "current_context",
        "search_captures",
        "search_memory",
        "read_recent_capture",
        "recent_activity",
        "privacy_status"
      ]
    },
    "read_only": {
      "const": true
    },
    "trust": {
      "type": "string",
      "enum": [
        "untrusted_observed_content",
        "local_privacy_status"
      ]
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "metadata_only": {
      "type": "boolean"
    },
    "share_warning": {
      "type": "string",
      "minLength": 1
    },
    "external_sharing": {
      "type": "object",
      "required": [
        "requires_user_approval",
        "metadata_only_available",
        "mcp_read_only"
      ],
      "additionalProperties": false,
      "properties": {
        "requires_user_approval": {
          "const": true
        },
        "metadata_only_available": {
          "const": true
        },
        "mcp_read_only": {
          "const": true
        }
      }
    },
    "result": {
      "type": "object"
    }
  }
}
