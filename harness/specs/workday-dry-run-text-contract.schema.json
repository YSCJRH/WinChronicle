{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WinChronicle workday dry-run text contract fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command",
    "expected_contains",
    "forbidden_substrings",
    "ordered_pairs"
  ],
  "properties": {
    "command": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_contains": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_substrings": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ordered_pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
