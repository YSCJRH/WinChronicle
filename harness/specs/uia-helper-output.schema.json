{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winchronicle.local/specs/uia-helper-output.schema.json",
  "title": "WinChronicle UIA Helper Output v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "helper_schema_version",
    "source",
    "command",
    "timestamp",
    "window",
    "focused_element",
    "visible_text",
    "url",
    "uia_tree",
    "limits",
    "uia_stats",
    "capture_target",
    "truncated",
    "capture_surfaces"
  ],
  "properties": {
    "helper_schema_version": {
      "const": 1
    },
    "source": {
      "const": "win-uia-helper"
    },
    "command": {
      "enum": ["capture-frontmost", "capture"]
    },
    "timestamp": {
      "type": "string"
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hwnd",
        "pid",
        "process_name",
        "exe_path",
        "app_name",
        "title",
        "bounds",
        "elevated"
      ],
      "properties": {
        "hwnd": {
          "type": "string"
        },
        "pid": {
          "type": "integer"
        },
        "process_name": {
          "type": "string"
        },
        "exe_path": {
          "type": "string"
        },
        "app_name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "bounds": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "elevated": {
          "type": "boolean"
        }
      }
    },
    "focused_element": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_type",
        "name",
        "automation_id",
        "class_name",
        "is_editable",
        "is_password",
        "value",
        "text"
      ],
      "properties": {
        "control_type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "automation_id": {
          "type": "string"
        },
        "class_name": {
          "type": "string"
        },
        "is_editable": {
          "type": "boolean"
        },
        "is_password": {
          "type": "boolean"
        },
        "value": {
          "type": ["string", "null"]
        },
        "text": {
          "type": ["string", "null"]
        }
      }
    },
    "visible_text": {
      "type": "string",
      "maxLength": 20000
    },
    "url": {
      "type": ["string", "null"]
    },
    "uia_tree": {
      "type": "object"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depth", "max_nodes", "max_text_chars", "node_count"],
      "properties": {
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 80
        },
        "max_nodes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5000
        },
        "max_text_chars": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20000
        },
        "node_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        }
      }
    },
    "uia_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes_visited",
        "nodes_skipped",
        "stale_nodes_skipped",
        "exceptions_skipped",
        "chars_collected",
        "elapsed_ms",
        "max_depth_observed",
        "time_budget_ms",
        "time_budget_exceeded",
        "max_nodes_reached",
        "max_depth_reached",
        "max_chars_reached"
      ],
      "properties": {
        "nodes_visited": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        },
        "nodes_skipped": {
          "type": "integer",
          "minimum": 0
        },
        "stale_nodes_skipped": {
          "type": "integer",
          "minimum": 0
        },
        "exceptions_skipped": {
          "type": "integer",
          "minimum": 0
        },
        "chars_collected": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20000
        },
        "elapsed_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_depth_observed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 80
        },
        "time_budget_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "time_budget_exceeded": {
          "type": "boolean"
        },
        "max_nodes_reached": {
          "type": "boolean"
        },
        "max_depth_reached": {
          "type": "boolean"
        },
        "max_chars_reached": {
          "type": "boolean"
        }
      }
    },
    "capture_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "hwnd",
        "requested_pid",
        "resolved_pid",
        "frontmost_at_capture",
        "harness_only"
      ],
      "properties": {
        "kind": {
          "enum": [
            "frontmost",
            "hwnd",
            "pid_window_title_regex",
            "process_name_window_title_regex"
          ]
        },
        "hwnd": {
          "type": "string",
          "pattern": "^0x[0-9A-Fa-f]{16}$"
        },
        "requested_pid": {
          "type": ["integer", "null"]
        },
        "resolved_pid": {
          "type": "integer",
          "minimum": 0
        },
        "frontmost_at_capture": {
          "type": "boolean"
        },
        "harness_only": {
          "type": "boolean"
        }
      }
    },
    "truncated": {
      "type": "boolean"
    },
    "capture_surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "screenshots",
        "ocr",
        "audio",
        "keyboard",
        "clipboard",
        "desktop_control"
      ],
      "properties": {
        "screenshots": {
          "const": false
        },
        "ocr": {
          "const": false
        },
        "audio": {
          "const": false
        },
        "keyboard": {
          "const": false
        },
        "clipboard": {
          "const": false
        },
        "desktop_control": {
          "const": false
        }
      }
    }
  }
}
