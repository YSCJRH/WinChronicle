{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winchronicle.local/specs/watcher-event.schema.json",
  "title": "WinChronicle Watcher Event v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_schema_version",
    "source",
    "event_id",
    "event_type",
    "timestamp"
  ],
  "properties": {
    "event_schema_version": {
      "const": 1
    },
    "source": {
      "const": "win-uia-watcher"
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "enum": ["foreground_changed", "name_changed", "value_changed", "heartbeat"]
    },
    "timestamp": {
      "type": "string"
    },
    "capture": {
      "type": "object"
    },
    "heartbeat_id": {
      "type": "string"
    }
  }
}
