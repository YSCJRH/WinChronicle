{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WinChronicle harness command plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "execution",
    "privacy",
    "command_count",
    "contract_coverage",
    "commands"
  ],
  "properties": {
    "schema": {
      "const": "winchronicle.harness.command_plan.v1"
    },
    "execution": {
      "const": "not_run"
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creates_harness_state",
        "starts_subprocesses",
        "reads_observed_content"
      ],
      "properties": {
        "creates_harness_state": {
          "const": false
        },
        "starts_subprocesses": {
          "const": false
        },
        "reads_observed_content": {
          "const": false
        }
      }
    },
    "command_count": {
      "type": "integer",
      "minimum": 1
    },
    "contract_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "command_index",
          "tests",
          "privacy_boundary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "minLength": 1
          },
          "command_index": {
            "type": "integer",
            "minimum": 1
          },
          "spec": {
            "type": "string",
            "minLength": 1
          },
          "fixtures": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^tests/.+::.+$"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "privacy_boundary": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": [
                "boolean",
                "string",
                "integer",
                "number",
                "array",
                "object",
                "null"
              ]
            }
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "argv",
          "display"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "display": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
